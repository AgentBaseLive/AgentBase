{
  "id": "extract_entities_v1",
  "name": "Extract Entities",
  "description": "Extracts named entities from text.",
  "input_schema": {
    "type": "object",
    "properties": {
      "text": { "type": "string" }
    },
    "required": ["text"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "entities": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "value": { "type": "string" }
          },
          "required": ["type", "value"]
        }
      }
    },
    "required": ["entities"]
  },
  "evaluator": "/public-endpoints/evaluators/extract_entities_v1.json"
}
