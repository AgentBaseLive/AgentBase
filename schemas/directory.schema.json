{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentBase Directory Schema",
  "type": "object",
  "properties": {
    "version": { "type": "string" },

    "tasks": {
      "type": "object",
      "properties": {
        "index": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "endpoint": { "type": "string" }
            },
            "required": ["id", "endpoint"],
            "additionalProperties": false
          }
        }
      },
      "required": ["index", "items"],
      "additionalProperties": false
    }
  },
  "required": ["version", "tasks"],
  "additionalProperties": false
}
